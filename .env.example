# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
APP_PORT=3000

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=loan_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long random string in production. e.g. openssl rand -hex 32
JWT_SECRET=changeme-use-a-long-random-secret-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use "*" only in development.
# Example: https://192.168.4.121:3000,https://your-domain.com
CORS_ALLOW_ORIGINS=*

# ── Mobile App API Key ────────────────────────────────────────────────────────
# Random secret shared with the mobile app. Sent as X-API-Key header.
# Required for POST /api/update-status (loan approval status changes).
# e.g. openssl rand -hex 24
MOBILE_API_KEY=your-mobile-api-key-here

# ── Cloudflare R2 Storage ────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=cmo-loan-app
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# ── Gemini AI (OCR) ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Default Admin Seed ────────────────────────────────────────────────────────
# Only used when the users table is empty (first run).
# Leave blank to skip auto-creating default users.
DEFAULT_ADMIN_PASSWORD=your_initial_password
